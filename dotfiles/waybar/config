{
    "layer": "top",
    "position": "bottom",
    "height": 41,
    "spacing": 4,
    "margin-top": 1,
    "margin-bottom":5,

    // Choose the order of the modules

    "modules-left":["idle_inhibitor", "pulseaudio", "cpu", "memory", "disk", "temperature"],
